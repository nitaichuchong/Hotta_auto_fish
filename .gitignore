# ------------------------------
# PyCharm IDE 相关文件 (核心)
# ------------------------------
# 主配置目录（包含项目设置、运行配置、断点等）
.idea/
# 临时文件
*.iws
*.iml
*.ipr
# 本地历史记录
.idea/workspace.xml
.idea/tasks.xml
.idea/launchConfigurations
.idea/gradle.xml
.idea/dictionaries
.idea/libraries
.idea/modules.xml
.idea/jarRepositories.xml
.idea/caches
.idea/inspectionProfiles/
.idea/shelf/
.idea/artifacts/
.idea/compiler.xml
.idea/copyright/profiles_settings.xml
.idea/externalDependencies.xml

# ------------------------------
# Python 项目通用忽略
# ------------------------------
# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# 分发/打包文件
*.egg-info/
dist/
build/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg
*.whl
*.manifest
*.spec

# 虚拟环境（不同命名的虚拟环境目录）
venv/
env/
ENV/
.venv/
.env/
env.local/
env.test/

# 缓存和日志
*.pyc
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.log
logs/

# 数据库文件
*.db
*.sqlite3
*.db-journal

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# ------------------------------
# 操作系统通用忽略
# ------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*